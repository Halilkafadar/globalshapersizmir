# ShapeBot Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# AI Model API Keys
# ============================================

# Groq (Primary - Llama-3.1-70B)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# DeepInfra (Secondary - Mistral-7B)
# Get from: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# Hugging Face (Fallback - Falcon-7B)
# Get from: https://huggingface.co/settings/tokens
HF_API_KEY=your_hf_api_key_here

# ============================================
# Database & Caching
# ============================================

# Redis (Session storage & rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Pinecone (Vector DB for RAG)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=shapebot-knowledge

# ============================================
# Application Settings
# ============================================

DEBUG=False
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=100

# Model Configuration
DEFAULT_MODEL=groq
PRIMARY_MODEL_TIMEOUT=15
SECONDARY_MODEL_TIMEOUT=10
FALLBACK_MODEL_TIMEOUT=5

# Token Budgets
MAX_TOKENS_PER_SESSION=2000
MAX_TOKENS_PER_REQUEST=1024
